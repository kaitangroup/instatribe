# ─── Database ──────────────────────────────────────────────────────────────────
# PostgreSQL connection string (required)
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL=postgresql://kindred_user:your_password@localhost:5432/kindred_db

# ─── App ───────────────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=4003

# ─── Session ───────────────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
SESSION_SECRET=replace_this_with_a_long_random_secret_string_at_least_64_chars

# ─── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins (your domain(s))
# Example: https://kindred.yourdomain.com,https://www.yourdomain.com
ALLOWED_ORIGINS=http://localhost:4003

# ─── Rate Limiting ─────────────────────────────────────────────────────────────
# Max requests per IP per 15 minutes (default: 300)
RATE_LIMIT_MAX=300
